# ===========================================
# SIKAP Frontend - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# =====================
# API Configuration
# =====================
# Flask backend route prefix: /api/v1
# Gunakan relative path agar otomatis lewat proxy Vite saat development.
VITE_API_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:5000
VITE_MQTT_WS_URL=ws://localhost:9001
VITE_MQTT_TOPIC_ABSENSI=absensi/realtime

# =====================
# App Configuration
# =====================
VITE_APP_NAME=SIKAP
VITE_GRAFANA_URL=http://localhost:3000
