# ============================================================================
# SIKAP - Environment Variables
# ============================================================================
# Copy file ini ke .env:  cp .env.example .env
# Jangan commit .env ke Git!
# ============================================================================

# --- Database ---
DB_ROOT_PASSWORD=sikap_root_2025
DB_NAME=sikap_db
DB_USER=sikap_user
DB_PASSWORD=sikap_pass_2025
DB_HOST=localhost
DB_PORT=3306
# Alternatif: pakai satu URL penuh
# DATABASE_URL=mysql+pymysql://sikap_user:sikap_pass_2025@localhost:3306/sikap_db

# --- Flask Backend ---
FLASK_ENV=development
FLASK_DEBUG=1
DEBUG_METRICS=1
FLASK_APP=run.py
APP_TIMEZONE=Asia/Jakarta
SECRET_KEY=dev-secret-key-ganti-di-production
JWT_SECRET_KEY=jwt-secret-key-ganti-di-production
JWT_ACTIVE_KID=v1
JWT_LEGACY_KID=v1
# Format: kid=secret;kid=secret
JWT_ADDITIONAL_SECRET_KEYS=
JWT_ACCESS_TOKEN_HOURS=12
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173
RFID_REQUIRE_SIGNATURE=0
RFID_SIGNATURE_TOLERANCE_SECONDS=120
RFID_PUBLIC_KEY_DIR=/app/keys/rfid_public
SP_AUTO_ENABLED=1
SP_CONSECUTIVE_ALPHA_THRESHOLDS=3,6,9
SP_EMAIL_ENABLED=1
GMAIL_CLIENT_SECRET_PATH=
GMAIL_TOKEN_PATH=backend/instance/gmail_token.json
GMAIL_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/oauth2callback
GMAIL_SENDER_EMAIL=

# --- Grafana (monitoring) ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
