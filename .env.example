# ===========================================
# SIKAP - Sistem Informasi Kehadiran Akademik dan Pembelajaran
# Environment Configuration Example
# ===========================================
# Copy this file to .env and fill in your values

# ======================
# Flask Configuration
# ======================
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# ======================
# Database Configuration
# ======================
DATABASE_URL=sqlite:///sikap.db
# For PostgreSQL: postgresql://user:password@localhost:5432/sikap

# ======================
# JWT Configuration
# ======================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=86400
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ======================
# Server Configuration
# ======================
HOST=0.0.0.0
PORT=5000
DEBUG=True

# ======================
# CORS Configuration
# ======================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ======================
# Email Configuration (Optional)
# ======================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password

# ======================
# Upload Configuration
# ======================
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf

# ======================
# RFID Device Configuration
# ======================
RFID_DEVICE_PORT=/dev/ttyUSB0
RFID_DEVICE_BAUDRATE=9600

# ======================
# Logging Configuration
# ======================
LOG_LEVEL=INFO
LOG_FILE=sikap.log
